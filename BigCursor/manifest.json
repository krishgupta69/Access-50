{
  "manifest_version": 3,
  "name": "BigCursor",
  "version": "1.0.0",
  "description": "Enlarges the mouse pointer and draws an adjustable halo so you never lose your cursor.",
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "assets/icon16.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  }
}
