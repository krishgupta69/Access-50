{
  "manifest_version": 3,
  "name": "SiteNotes",
  "version": "1.0.0",
  "description": "Draggable sticky notes pinned to any page, saved per-URL and restored on revisit.",
  "permissions": ["storage", "tabs", "activeTab"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["storage.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "commands": {
    "add-note": {
      "suggested_key": {
        "default": "Alt+Shift+N"
      },
      "description": "Add a note to this page"
    }
  },
  "icons": {
    "16": "assets/icon16.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  }
}
